---
import '@/styles/global.css'
import { ClientRouter } from 'astro:transitions'
import SearchModal from '@/components/search/SearchModal.astro'
import Seo from '@/components/Seo.astro'
import HeadTags from '@/components/HeadTags.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import ClickSpark from '@/components/layout/ClickSpark.astro'
import type { PageSeo } from '@/lib/seo'
import type { Locale } from '@/lib/routes'
import { t } from '@/i18n/messages'
import { SITE_URL, PERSONAL } from '@/constants/site'

interface Props {
  locale: Locale
  seo: PageSeo
  navAlternates: Record<Locale, string>
}

const { locale, seo, navAlternates } = Astro.props

const websiteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/#person`,
      name: PERSONAL.name.full,
      url: SITE_URL,
      sameAs: [PERSONAL.social.github, PERSONAL.social.linkedin],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: `${PERSONAL.name.short} Blog`,
      publisher: { '@id': `${SITE_URL}/#person` },
    },
  ],
}
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <HeadTags />
    <ClientRouter />
    <Seo locale={locale} {...seo} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteGraph)}
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-content1 focus:px-4 focus:py-2 focus:shadow-lg"
    >
      {t(locale, 'Navigation.skipToContent')}
    </a>
    <Header locale={locale} alternates={navAlternates} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <SearchModal locale={locale} />
    <ClickSpark />
  </body>
</html>
