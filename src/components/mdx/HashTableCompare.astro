---
import HashTablePanel from './HashTablePanel.astro'

interface HashTableEntry {
  key: string
  value: string | number
}

interface ProbeStep {
  slot: number
  outcome: 'skip' | 'found' | 'stop'
}

interface HashTableBucket {
  entries?: HashTableEntry[]
  tombstone?: boolean
}

interface Props {
  leftTitle: string
  rightTitle: string
  leftBuckets: HashTableBucket[]
  rightBuckets: HashTableBucket[]
  leftProbeSteps?: ProbeStep[]
  rightProbeSteps?: ProbeStep[]
}

const {
  leftTitle,
  rightTitle,
  leftBuckets,
  rightBuckets,
  leftProbeSteps,
  rightProbeSteps,
} = Astro.props
---

<div class="my-8 w-full">
  <div
    class="bg-linear-to-br from-content1 to-content2 border border-divider rounded-xl p-6 w-full"
  >
    <div class="flex flex-col sm:flex-row gap-6">
      <HashTablePanel
        title={leftTitle}
        buckets={leftBuckets}
        probeSteps={leftProbeSteps}
      />
      <div class="hidden sm:block w-px bg-divider shrink-0"></div>
      <div class="block sm:hidden h-px bg-divider"></div>
      <HashTablePanel
        title={rightTitle}
        buckets={rightBuckets}
        probeSteps={rightProbeSteps}
      />
    </div>

    {
      Astro.slots.has('default') && (
        <div class="font-mono text-foreground/70 text-center text-sm border-t border-divider pt-4 mt-5">
          <slot />
        </div>
      )
    }
  </div>
</div>
