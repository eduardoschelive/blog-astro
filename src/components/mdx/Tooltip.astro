---
import Icon from './Icon.astro'

interface Props {
  content: string
  title?: string
}

const { content, title } = Astro.props
---

<span class="tooltip">
  <span
    class="tooltip-trigger text-secondary underline decoration-2 decoration-secondary/40 underline-offset-2 hover:decoration-secondary cursor-pointer font-medium"
    tabindex="0"
    role="button"
  >
    <slot />
  </span>
  <span class="tooltip-bubble" role="tooltip">
    <span class="flex gap-2">
      <Icon
        name="info-circle"
        size={16}
        class="text-secondary shrink-0 mt-0.5"
      />
      <span class="flex flex-col gap-1.5">
        {title && <span class="font-semibold text-secondary text-sm">{title}</span>}
        <span class="text-foreground/90 leading-relaxed text-sm text-justify">
          {content}
        </span>
      </span>
    </span>
  </span>
</span>
