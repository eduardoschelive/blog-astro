---
interface Props {
  bits: number | 'platform'
}

const { bits } = Astro.props
const MAX_BITS = 128
const filledBlocks = bits === 'platform' ? 0 : Math.round((bits / MAX_BITS) * 16)
---

{
  bits === 'platform' ? (
    <div class="flex items-center gap-2">
      <div class="flex gap-0.5">
        {Array.from({ length: 4 }).map(() => (
          <div class="h-3 w-3 rounded-sm bg-warning/40 border border-warning/50" />
        ))}
        <span class="text-warning text-xs ml-1 font-bold">?</span>
      </div>
      <span class="text-default-400 text-xs">platform-dependent</span>
    </div>
  ) : (
    <div class="flex items-center gap-2">
      <div class="flex gap-0.5">
        {Array.from({ length: 16 }).map((_, i) => (
          <div
            class:list={[
              'h-3 w-3 rounded-sm',
              i < filledBlocks
                ? 'bg-primary/70 border border-primary/80'
                : 'bg-content4/30 border border-content4/40',
            ]}
          />
        ))}
      </div>
      <span class="text-default-400 text-xs font-mono">{bits} bits</span>
    </div>
  )
}
