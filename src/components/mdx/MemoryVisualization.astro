---
interface MemoryBlock {
  address: string
  value: string | number
  label?: string
  nextAddress?: string
}

interface Props {
  title: string
  type: 'contiguous' | 'linked'
  blocks: MemoryBlock[]
  summary?: string
}

const { title, type, blocks, summary } = Astro.props
const hasFooter = summary !== undefined || Astro.slots.has('default')
---

<div class="my-8 flex justify-center w-full">
  <div
    class="bg-linear-to-br from-content1 to-content2 border border-divider rounded-xl p-6 w-full"
  >
    <div class="text-primary font-mono text-sm font-semibold mb-4">{title}</div>

    <div
      class:list={[
        type === 'contiguous'
          ? 'flex gap-2 sm:gap-3 mb-5 flex-wrap justify-center'
          : 'flex flex-col gap-5 mb-5',
      ]}
    >
      <div class="flex items-center gap-3 flex-wrap justify-center">
        {
          blocks.map((block, index) => (
            <div class="flex items-center gap-3">
              <div class="bg-content2 border-2 border-primary rounded-lg p-4 min-w-[140px] sm:min-w-[200px] text-center">
                <div class="text-secondary font-mono text-xs mb-2 flex items-center justify-center gap-1">
                  {type === 'linked' && <span>📍</span>}
                  <span>{block.address}</span>
                </div>
                <div class="text-success text-xl sm:text-2xl font-bold mb-1">
                  {block.value}
                </div>
                {block.label && (
                  <div class="text-primary text-xs mt-1">{block.label}</div>
                )}
                {block.nextAddress && (
                  <div class="text-primary text-xs font-mono mt-2">
                    próximo → {block.nextAddress}
                  </div>
                )}
              </div>
              {type === 'linked' && index < blocks.length - 1 && (
                <div class="text-danger text-3xl">→</div>
              )}
            </div>
          ))
        }
      </div>
    </div>

    {
      hasFooter && (
        <div class="font-mono text-foreground text-center text-sm border-t border-divider pt-4 mt-4">
          {summary !== undefined ? summary : <slot />}
        </div>
      )
    }
  </div>
</div>
