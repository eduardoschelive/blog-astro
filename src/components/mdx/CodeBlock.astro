---
import Icon from './Icon.astro'

// Overrides `pre` for fenced code blocks. Astro's Shiki has already produced
// the highlighted <code> (passed as the slot); we add the card chrome and
// copy/download actions. The raw text for those actions is read from the DOM
// at runtime, so no code string needs to be duplicated here.
const props = Astro.props
const lang = props['data-language'] ?? ''
const btn =
  'p-1.5 rounded-md text-foreground/50 hover:text-foreground hover:bg-content3 transition-colors cursor-pointer'
---

<div
  class="code-block not-prose my-6 bg-content1 rounded-lg shadow-lg border border-divider"
>
  <div
    class="flex items-center justify-between px-4 py-3 bg-content2 rounded-t-lg"
  >
    <span class="flex space-x-2">
      <span class="w-3 h-3 rounded-full bg-danger block shrink-0"></span>
      <span class="w-3 h-3 rounded-full bg-warning block shrink-0"></span>
      <span class="w-3 h-3 rounded-full bg-success block shrink-0"></span>
    </span>
    <div class="code-actions flex items-center gap-1" data-lang={lang}>
      <button type="button" class:list={['code-copy', btn]}>
        <Icon name="copy" size={16} class="icon-copy" />
        <Icon name="check" size={16} class="icon-check hidden" />
      </button>
      <button type="button" class:list={['code-download', btn]}>
        <Icon name="download" size={16} />
      </button>
    </div>
  </div>
  <div class="overflow-x-auto p-4">
    <pre {...props}><slot /></pre>
  </div>
</div>

<script>
  const EXT: Record<string, string> = {
    typescript: 'ts', ts: 'ts', tsx: 'tsx',
    javascript: 'js', js: 'js', jsx: 'jsx', mjs: 'mjs', cjs: 'cjs',
    bash: 'sh', sh: 'sh', shell: 'sh', zsh: 'zsh',
    c: 'c', cpp: 'cpp', 'c++': 'cpp',
    python: 'py', py: 'py', java: 'java', go: 'go', golang: 'go',
  }
  const LABELS = {
    pt: { copy: 'Copiar código', copied: 'Copiado!', download: 'Baixar código' },
    en: { copy: 'Copy code', copied: 'Copied!', download: 'Download code' },
  }
  const L = document.documentElement.lang.startsWith('pt') ? LABELS.pt : LABELS.en

  const readCode = (block: Element): string => {
    const lines = block.querySelectorAll('pre code .line')
    if (lines.length) {
      return Array.from(lines)
        .map((l) => l.textContent ?? '')
        .join('\n')
    }
    return block.querySelector('pre')?.textContent ?? ''
  }

  document.querySelectorAll<HTMLElement>('.code-block').forEach((block) => {
    const raw = readCode(block)
    const actions = block.querySelector('.code-actions')
    const lang = (actions?.getAttribute('data-lang') ?? '').toLowerCase()
    const copyBtn = block.querySelector<HTMLButtonElement>('.code-copy')
    const dlBtn = block.querySelector<HTMLButtonElement>('.code-download')

    if (copyBtn) {
      copyBtn.title = L.copy
      copyBtn.setAttribute('aria-label', L.copy)
      const iconCopy = copyBtn.querySelector('.icon-copy')
      const iconCheck = copyBtn.querySelector('.icon-check')
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(raw)
        } catch {
          return
        }
        iconCopy?.classList.add('hidden')
        iconCheck?.classList.remove('hidden')
        copyBtn.title = L.copied
        setTimeout(() => {
          iconCopy?.classList.remove('hidden')
          iconCheck?.classList.add('hidden')
          copyBtn.title = L.copy
        }, 1500)
      })
    }

    if (dlBtn) {
      dlBtn.title = L.download
      dlBtn.setAttribute('aria-label', L.download)
      dlBtn.addEventListener('click', () => {
        const blob = new Blob([raw], { type: 'text/plain' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = `snippet.${EXT[lang] ?? 'txt'}`
        a.click()
        URL.revokeObjectURL(url)
      })
    }
  })
</script>
