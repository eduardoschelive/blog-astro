---
import Icon, { type IconName } from './Icon.astro'

type CalloutType = 'info' | 'warning' | 'success' | 'danger' | 'note'

interface Props {
  type?: CalloutType
  title?: string
}

const { type = 'info', title } = Astro.props

const styles: Record<
  CalloutType,
  { card: string; icon: string; title: string; glyph: IconName }
> = {
  info: {
    card: 'bg-primary/10 border-l-primary',
    icon: 'text-primary',
    title: 'text-primary',
    glyph: 'info-circle',
  },
  warning: {
    card: 'bg-warning/10 border-l-warning',
    icon: 'text-warning',
    title: 'text-warning',
    glyph: 'alert-triangle',
  },
  success: {
    card: 'bg-success/10 border-l-success',
    icon: 'text-success',
    title: 'text-success',
    glyph: 'check',
  },
  danger: {
    card: 'bg-danger/10 border-l-danger',
    icon: 'text-danger',
    title: 'text-danger',
    glyph: 'x',
  },
  note: {
    card: 'bg-secondary/10 border-l-secondary',
    icon: 'text-secondary',
    title: 'text-secondary',
    glyph: 'bulb',
  },
}

const s = styles[type]
---

<div class:list={['my-4 border-l-4 rounded-lg', s.card]}>
  <div class="p-3">
    <div class="flex items-start gap-3">
      <Icon name={s.glyph} class:list={['shrink-0 mt-0.5', s.icon]} />
      <div class="grow min-w-0">
        {title && <h4 class:list={['font-semibold mb-1', s.title]}>{title}</h4>}
        <div
          class="text-foreground/90 text-sm [&>p]:my-2 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0 [&>code]:text-xs"
        >
          <slot />
        </div>
      </div>
    </div>
  </div>
</div>
