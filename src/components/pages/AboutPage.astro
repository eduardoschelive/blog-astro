---
import Icon from '../mdx/Icon.astro'
import { t } from '../../i18n/messages'
import { PERSONAL } from '../../constants/site'
import type { Locale } from '../../lib/routes'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const years = new Date().getFullYear() - 2013
const intro = t(locale, 'AboutPage.intro').replace('{years}', String(years))
const profile =
  'https://res.cloudinary.com/dzttinf61/image/upload/w_600,h_650,c_fill,g_center/profile'

const curiosities = ['techstack', 'minecraft', 'clipper'] as const
const SKRIPT_LINK = 'https://github.com/SkriptLang/Skript'
---

<div class="mx-auto max-w-5xl px-4 py-16">
  <section class="grid items-center gap-10 md:grid-cols-2">
    <div>
      <p class="font-mono text-sm uppercase tracking-widest text-primary">
        {t(locale, 'AboutPage.greeting')}
      </p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
        {PERSONAL.name.full}
      </h1>
      <p class="mt-6 text-lg text-foreground/70">{intro}</p>
      <p class="mt-4 text-lg text-foreground/70">
        {t(locale, 'AboutPage.experience')}
      </p>
      <div class="mt-8 flex gap-3">
        <a
          href={PERSONAL.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="p-2.5 rounded-full border border-divider text-foreground/70 hover:text-primary hover:border-primary transition-colors"
        >
          <Icon name="brand-github" size={22} />
        </a>
        <a
          href={PERSONAL.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="p-2.5 rounded-full border border-divider text-foreground/70 hover:text-primary hover:border-primary transition-colors"
        >
          <Icon name="brand-linkedin" size={22} />
        </a>
        <a
          href={`mailto:${PERSONAL.social.email}`}
          aria-label="Email"
          class="p-2.5 rounded-full border border-divider text-foreground/70 hover:text-primary hover:border-primary transition-colors"
        >
          <Icon name="mail" size={22} />
        </a>
      </div>
    </div>

    <div
      data-tilt
      class="relative mx-auto w-full max-w-sm [transform-style:preserve-3d] transition-transform duration-300 ease-out will-change-transform"
    >
      <div
        class="absolute -inset-1 rounded-2xl bg-linear-to-r from-primary via-secondary to-primary opacity-40 blur-lg"
      >
      </div>
      <img
        src={profile}
        alt={PERSONAL.name.full}
        width="600"
        height="650"
        class="relative w-full rounded-2xl object-cover shadow-2xl ring-2 ring-primary/20"
      />
    </div>
  </section>

  <section class="mt-20">
    <h2 class="mb-8 text-2xl font-bold">{t(locale, 'AboutPage.curiosities.title')}</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {
        curiosities.map((key) => (
          <div class="rounded-2xl border border-divider/50 bg-content2 p-6">
            <h3 class="mb-2 font-bold text-primary">
              {t(locale, `AboutPage.curiosities.${key}.title`)}
            </h3>
            <p class="text-sm leading-relaxed text-foreground/70">
              {t(locale, `AboutPage.curiosities.${key}.description`)}
              {key === 'minecraft' && (
                <>
                  {' '}
                  <a
                    href={SKRIPT_LINK}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary underline"
                  >
                    {t(locale, 'AboutPage.curiosities.minecraft.link')}
                  </a>{' '}
                  {t(locale, 'AboutPage.curiosities.minecraft.continuation')}
                </>
              )}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</div>

<script>
  function initTilt() {
    const MAX = 5
    document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((el) => {
      if (window.matchMedia('(hover: none)').matches) return
      el.addEventListener('mousemove', (e) => {
        const r = el.getBoundingClientRect()
        const rx = ((e.clientY - r.top - r.height / 2) / (r.height / 2)) * -MAX
        const ry = ((e.clientX - r.left - r.width / 2) / (r.width / 2)) * MAX
        el.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg)`
      })
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)'
      })
    })
  }
  document.addEventListener('astro:page-load', initTilt)
</script>
