---
import ArticleBody from '../mdx/ArticleBody.astro'
import ArticleCard from '../layout/ArticleCard.astro'
import Icon from '../mdx/Icon.astro'
import { getArticlesByCategoryDir, formatDate, readingLabel } from '../../lib/content'
import { getCategoryAccent } from '../../constants/categoryVisuals'
import { t } from '../../i18n/messages'
import type { PageRoute } from '../../lib/routes'

interface Props {
  route: PageRoute
}

const { route } = Astro.props
const locale = route.locale
const entry = route.article!
const data = entry.data
const categoryDir = route.categoryDir!
const currentUrl = route.alternates[locale]

const siblings = await getArticlesByCategoryDir(locale, categoryDir)
const index = siblings.findIndex((s) => s.url === currentUrl)
const prev = index > 0 ? siblings[index - 1] : null
const next = index >= 0 && index < siblings.length - 1 ? siblings[index + 1] : null
const related = siblings.filter((s) => s.url !== currentUrl).slice(0, 3)

const current = siblings[index]
const accent = getCategoryAccent(categoryDir)
const readingMinutes = current?.readingMinutes ?? 1
const categoryTitle = current?.categoryTitle ?? ''
const categoryUrl = route.alternates[locale].split('/articles/')[0]
---

<article class="mx-auto max-w-3xl px-4 py-10">
  <a
    href={categoryUrl}
    class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-widest text-primary"
  >
    <Icon name="folder" size={14} />
    {categoryTitle}
  </a>

  <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{data.title}</h1>

  {data.description && <p class="mt-4 text-lg text-foreground/70">{data.description}</p>}

  <div class="mt-4 flex flex-wrap items-center gap-2 text-sm text-default-400">
    <span>{formatDate(data.publishedAt, locale)}</span>
    <span aria-hidden>·</span>
    <span>{readingLabel(readingMinutes, locale)}</span>
    {
      data.updatedAt && (
        <>
          <span aria-hidden>·</span>
          <span>{t(locale, 'Article.updatedAt').replace('{date}', formatDate(data.updatedAt, locale))}</span>
        </>
      )
    }
  </div>

  <hr class="my-8 border-divider" />

  <ArticleBody entry={entry} />

  <nav class="mt-16 grid gap-4 sm:grid-cols-2" aria-label={t(locale, 'Article.navigation.label')}>
    {
      prev ? (
        <a
          href={prev.url}
          class="group flex flex-col gap-1 rounded-xl border border-divider/50 bg-content2 p-4 transition-colors hover:border-primary/40"
        >
          <span class="inline-flex items-center gap-1 text-xs text-default-400">
            <Icon name="arrow-left" size={14} />
            {t(locale, 'Article.navigation.previous')}
          </span>
          <span class="font-medium line-clamp-1 group-hover:text-primary">{prev.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    {
      next && (
        <a
          href={next.url}
          class="group flex flex-col items-end gap-1 rounded-xl border border-divider/50 bg-content2 p-4 text-right transition-colors hover:border-primary/40 sm:col-start-2"
        >
          <span class="inline-flex items-center gap-1 text-xs text-default-400">
            {t(locale, 'Article.navigation.next')}
            <Icon name="arrow-right" size={14} />
          </span>
          <span class="font-medium line-clamp-1 group-hover:text-primary">{next.title}</span>
        </a>
      )
    }
  </nav>

  {
    related.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-2xl font-bold">{t(locale, 'Article.related.title')}</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((a) => (
            <ArticleCard
              article={a}
              locale={locale}
              linkText={t(locale, 'Categories.readArticle')}
              accent={accent}
            />
          ))}
        </div>
      </section>
    )
  }
</article>
