---
import ArticleCard from '../layout/ArticleCard.astro'
import { getArticlesByCategoryDir, articleCountLabel } from '../../lib/content'
import { ACCENT_CLASSES, getCategoryAccent } from '../../constants/categoryVisuals'
import { t } from '../../i18n/messages'
import type { PageRoute } from '../../lib/routes'

interface Props {
  route: PageRoute
}

const { route } = Astro.props
const locale = route.locale
const category = route.category!
const categoryDir = route.categoryDir!
const articles = await getArticlesByCategoryDir(locale, categoryDir)
const accent = getCategoryAccent(categoryDir)
const a = ACCENT_CLASSES[accent]
---

<div class="mx-auto max-w-5xl px-4 py-12">
  <header class="mb-10 max-w-2xl">
    <div class="mb-3 flex items-center gap-2">
      <span class:list={['h-1.5 w-1.5 rounded-full', a.dot]}></span>
      <span
        class="font-mono text-[11px] font-medium uppercase tracking-widest text-default-400"
      >
        {articleCountLabel(articles.length, locale)}
      </span>
    </div>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{category.data.title}</h1>
    <p class="mt-4 text-lg text-foreground/70">{category.data.description}</p>
  </header>

  {
    articles.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <ArticleCard
            article={article}
            locale={locale}
            linkText={t(locale, 'Categories.readArticle')}
            accent={accent}
            total={articles.length}
          />
        ))}
      </div>
    ) : (
      <p class="text-foreground/50">{t(locale, 'Categories.comingSoon')}</p>
    )
  }
</div>
