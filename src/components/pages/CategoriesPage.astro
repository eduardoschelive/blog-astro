---
import CategoryCard from '../layout/CategoryCard.astro'
import { getCategorySummaries } from '../../lib/content'
import { t } from '../../i18n/messages'
import type { Locale } from '../../lib/routes'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const categories = await getCategorySummaries(locale)
---

<div class="mx-auto max-w-5xl px-4 py-12">
  <header class="mb-10 max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      {t(locale, 'Categories.title')}
    </h1>
    <p class="mt-4 text-lg text-foreground/70">{t(locale, 'Categories.subtitle')}</p>
  </header>

  <div class="grid gap-6 md:grid-cols-2">
    {categories.map((category) => <CategoryCard category={category} locale={locale} />)}
  </div>
</div>
