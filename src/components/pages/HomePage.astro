---
import ArticleCard from '../layout/ArticleCard.astro'
import Icon from '../mdx/Icon.astro'
import { getArticleSummaries, formatDate, readingLabel } from '../../lib/content'
import { STATIC_SEGMENTS, type Locale } from '../../lib/routes'
import { t } from '../../i18n/messages'
import { PERSONAL } from '../../constants/site'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const articles = await getArticleSummaries(locale)
const featured = articles[0]
const recent = articles.slice(1, 7)
const categoriesHref = `/${locale}/${STATIC_SEGMENTS.categories[locale]}`
const readArticle = t(locale, 'Categories.readArticle')
---

<section class="mx-auto max-w-5xl px-4 py-16">
  <div class="max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      {PERSONAL.name.short}
    </h1>
    <p class="mt-4 text-lg text-foreground/70">
      {t(locale, 'Metadata.home.description')}
    </p>
  </div>

  {
    featured && (
      <a
        href={featured.url}
        class="group mt-10 block overflow-hidden rounded-2xl border border-divider/50 bg-content2 p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/40"
      >
        <span class="inline-flex items-center gap-2 font-mono text-[11px] font-medium uppercase tracking-widest text-primary">
          <span class="h-1.5 w-1.5 rounded-full bg-primary" />
          {featured.categoryTitle}
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight group-hover:text-primary">
          {featured.title}
        </h2>
        <p class="mt-3 line-clamp-2 text-foreground/70">{featured.description}</p>
        <div class="mt-4 flex items-center gap-2 text-sm text-default-400">
          <span>{formatDate(featured.publishedAt, locale)}</span>
          <span aria-hidden>·</span>
          <span>{readingLabel(featured.readingMinutes, locale)}</span>
        </div>
      </a>
    )
  }

  {
    recent.length > 0 && (
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((article) => (
          <ArticleCard article={article} locale={locale} linkText={readArticle} />
        ))}
      </div>
    )
  }

  <div class="mt-12 text-center">
    <a
      href={categoriesHref}
      class="inline-flex items-center gap-1.5 rounded-full border border-divider px-5 py-2.5 font-medium transition-colors hover:border-primary hover:text-primary"
    >
      {t(locale, 'Categories.title')}
      <Icon name="arrow-right" size={18} />
    </a>
  </div>
</section>
