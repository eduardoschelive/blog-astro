---
import Icon from '@/components/mdx/Icon.astro'
import {
  getArticleSummaries,
  getCategorySummaries,
  formatDate,
  readingLabel,
} from '@/lib/content'
import { STATIC_SEGMENTS, type Locale } from '@/lib/routes'
import { t } from '@/i18n/messages'
import { PERSONAL } from '@/constants/site'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const articles = await getArticleSummaries(locale)
const categories = await getCategorySummaries(locale)
const catUrlBySlug = new Map(categories.map((c) => [c.slug, c.url]))

const featured = articles[0]
const latest = articles.slice(0, 10)

const aboutHref = `/${locale}/${STATIC_SEGMENTS.about[locale]}`
const categoriesHref = `/${locale}/${STATIC_SEGMENTS.categories[locale]}`
const readMore = t(locale, 'HomePage.latest.readMore')
const featuredCategoryUrl = featured
  ? (catUrlBySlug.get(featured.categorySlug) ?? categoriesHref)
  : categoriesHref
---

<!-- Hero -->
<section
  class="relative flex min-h-[calc(100vh-64px)] items-center justify-center overflow-hidden px-4 py-12"
>
  <div class="relative z-10 mx-auto w-full max-w-7xl">
    <div class="flex flex-col items-center gap-8 lg:grid lg:grid-cols-2 lg:gap-16">
      <!-- Left: intro -->
      <div class="w-full space-y-6 lg:space-y-8">
        <div class="space-y-3 lg:space-y-4">
          <h1 class="text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
            <span
              class="mb-2 block text-xl font-normal text-foreground/80 sm:text-2xl lg:text-3xl"
            >
              {t(locale, 'Hero.greeting')}
            </span>
            <span class="block text-secondary">{PERSONAL.name.full}</span>
          </h1>
          <p
            class="max-w-xl text-base leading-relaxed text-foreground/70 sm:text-lg lg:text-xl xl:text-2xl"
          >
            {t(locale, 'Hero.subtitle')}
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:gap-4">
          <a
            href={aboutHref}
            class="inline-flex h-12 w-full items-center justify-center rounded-xl bg-primary px-6 font-semibold text-primary-foreground shadow-lg transition-transform hover:scale-105 sm:w-auto"
          >
            {t(locale, 'Hero.aboutButton')}
          </a>
          <a
            href={categoriesHref}
            class="inline-flex h-12 w-full items-center justify-center rounded-xl border border-default bg-transparent px-6 font-semibold text-foreground shadow-lg transition-transform hover:scale-105 sm:w-auto"
          >
            {t(locale, 'Hero.articlesButton')}
          </a>
        </div>
      </div>

      <!-- Right: latest article spotlight -->
      {
        featured && (
          <div class="w-full">
            <p class="mb-4 flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary sm:text-sm">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75" />
                <span class="relative inline-flex h-2 w-2 rounded-full bg-primary" />
              </span>
              {t(locale, 'Hero.featuredArticle')}
            </p>

            <article class="group relative overflow-hidden rounded-2xl border border-divider/50 bg-content2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10">
              <div
                aria-hidden
                class="pointer-events-none absolute -right-24 -top-24 h-48 w-48 rounded-full bg-primary/20 opacity-60 blur-3xl transition-opacity duration-500 group-hover:opacity-100"
              />
              <span
                aria-hidden
                class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary via-secondary to-primary"
              />

              <a
                href={featured.url}
                aria-label={`${t(locale, 'Hero.readMore')}: ${featured.title}`}
                class="absolute inset-0 z-10 rounded-2xl"
              />

              <div class="relative p-6 sm:p-8">
                <a
                  href={featuredCategoryUrl}
                  class="relative z-20 inline-flex h-7 w-fit items-center gap-1.5 rounded-full border border-primary/40 bg-primary/10 px-3 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
                >
                  <Icon name="folder" size={12} />
                  {featured.categoryTitle}
                </a>

                <h2 class="mt-4 text-2xl font-bold leading-tight tracking-tight line-clamp-3 transition-colors duration-300 group-hover:text-primary sm:text-3xl lg:text-4xl">
                  {featured.title}
                </h2>

                <p class="mt-3 text-sm leading-relaxed text-foreground/70 line-clamp-3 sm:text-base">
                  {featured.description}
                </p>

                <div class="mt-6 flex items-center gap-3 text-xs text-default-400">
                  <span class="inline-flex items-center gap-1">
                    <Icon name="calendar" size={14} />
                    <time datetime={featured.publishedAt}>
                      {formatDate(featured.publishedAt, locale)}
                    </time>
                  </span>
                  <span aria-hidden>·</span>
                  <span class="inline-flex items-center gap-1">
                    <Icon name="clock" size={14} />
                    {readingLabel(featured.readingMinutes, locale)}
                  </span>
                </div>

                <span class="mt-6 inline-flex w-fit items-center gap-2 text-sm font-bold text-primary sm:text-base">
                  {t(locale, 'Hero.readMore')}
                  <span
                    aria-hidden
                    class="transition-transform duration-300 group-hover:translate-x-1"
                  >
                    →
                  </span>
                </span>
              </div>
            </article>
          </div>
        )
      }
    </div>
  </div>

  <!-- Scroll-down hint -->
  <a
    href="#latest"
    aria-label={t(locale, 'Hero.scrollDown')}
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 rounded-full p-2 transition-transform hover:scale-110 md:flex"
  >
    <Icon name="chevron-down" size={32} class="animate-bounce text-primary" />
  </a>
</section>

<!-- Latest articles + categories sidebar -->
<div id="latest" class="w-full px-4 py-8 md:py-12">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-[3fr_1fr] lg:gap-12">
      <div class="w-full">
        <section class="w-full">
          <div class="mb-12">
            <h2 class="text-3xl font-bold md:text-4xl">
              {t(locale, 'HomePage.latest.title')}
            </h2>
          </div>

          <div class="grid gap-8">
            {
              latest.map((article) => (
                <article class="reveal group relative flex h-full flex-col overflow-hidden rounded-2xl border border-divider/50 bg-content2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-lg">
                  <a
                    href={article.url}
                    aria-label={`${readMore}: ${article.title}`}
                    class="absolute inset-0 z-10 rounded-2xl"
                  />
                  <div class="flex flex-col gap-4 p-6 md:p-8">
                    <div class="flex items-center justify-between gap-3">
                      <span class="inline-flex items-center gap-2 font-mono text-[11px] font-medium uppercase tracking-widest text-primary">
                        <span class="h-1.5 w-1.5 rounded-full bg-primary" />
                        {article.categoryTitle}
                      </span>
                    </div>
                    <h3 class="text-2xl font-bold leading-tight tracking-tight line-clamp-2 transition-colors duration-300 group-hover:text-primary md:text-3xl">
                      {article.title}
                    </h3>
                    <p class="max-w-3xl text-sm leading-relaxed text-default-400 line-clamp-2 md:text-base">
                      {article.description}
                    </p>
                    <div class="mt-2 flex items-center justify-between border-t border-divider/40 pt-4">
                      <div class="flex items-center gap-2 text-xs text-default-400">
                        <span class="inline-flex items-center gap-1">
                          <Icon name="calendar" size={14} />
                          <time datetime={article.publishedAt}>
                            {formatDate(article.publishedAt, locale)}
                          </time>
                        </span>
                        <span aria-hidden>·</span>
                        <span class="inline-flex items-center gap-1">
                          <Icon name="clock" size={14} />
                          {readingLabel(article.readingMinutes, locale)}
                        </span>
                      </div>
                      <span class="inline-flex items-center gap-1 text-sm font-medium text-primary">
                        {readMore}
                        <span aria-hidden>→</span>
                      </span>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="mt-12 text-center">
            <a
              href={categoriesHref}
              class="inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-primary px-6 font-semibold text-primary-foreground transition-opacity hover:opacity-90"
            >
              {t(locale, 'HomePage.latest.viewAll')}
              <span aria-hidden>→</span>
            </a>
          </div>
        </section>
      </div>

      <!-- Categories sidebar -->
      <aside class="sticky top-20 mt-24 hidden self-start lg:top-24 lg:block">
        <div class="mb-6 flex items-center">
          <a
            href={categoriesHref}
            class="inline-flex w-fit items-center gap-1 text-2xl font-semibold text-primary transition-opacity hover:opacity-80"
          >
            {t(locale, 'HomePage.categories.title')}
            <span aria-hidden>→</span>
          </a>
        </div>
        <div class="space-y-3">
          {
            categories.map((category) => (
              <a
                href={category.url}
                class="group block border-l-2 border-secondary/40 py-2 pl-4 transition-all duration-300 hover:border-primary"
              >
                <div class="mb-1 flex min-w-0 items-baseline justify-between gap-2">
                  <h3 class="min-w-0 flex-1 truncate font-semibold text-foreground transition-colors duration-200 group-hover:text-primary">
                    {category.title}
                  </h3>
                  <span class="shrink-0 text-xs tabular-nums text-foreground/80 transition-colors duration-200 group-hover:text-secondary">
                    {category.articleCount}
                  </span>
                </div>
                <p class="text-xs text-foreground/80 line-clamp-2 transition-colors duration-200 group-hover:text-foreground">
                  {category.description}
                </p>
              </a>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</div>
