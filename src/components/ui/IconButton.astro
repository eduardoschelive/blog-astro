---
import Tooltip from './Tooltip.astro'

interface Props {
  label: string
  href?: string
  variant?: 'ghost' | 'outline'
  class?: string
  [key: string]: unknown
}

const { label, href, variant = 'ghost', class: className = '', ...rest } = Astro.props

const variants = {
  ghost: 'hover:bg-content3 hover:text-foreground',
  outline: 'border border-divider hover:border-primary hover:text-primary',
}
const round = `inline-grid size-10 place-items-center rounded-full text-foreground/70 transition-colors ${variants[variant]}`
---

<Tooltip
  content={label}
  icon={false}
  hoverOnly
  href={href}
  triggerClass={`${round} ${className}`}
  aria-label={label}
  {...rest}
>
  <slot />
</Tooltip>
