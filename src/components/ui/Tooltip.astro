---
import { Icon } from 'astro-icon/components'

interface Props {
  content: string
  title?: string
  icon?: boolean
  triggerClass?: string
}

const defaultTrigger =
  'text-secondary underline decoration-2 decoration-secondary/40 underline-offset-2 hover:decoration-secondary font-medium cursor-pointer'

const { content, title, icon = true, triggerClass = defaultTrigger } = Astro.props
const id = `tooltip-${crypto.randomUUID()}`
---

<span class="tooltip-root" data-tooltip>
  <button
    type="button"
    class:list={['tooltip-trigger', triggerClass]}
    data-tooltip-trigger
    aria-describedby={id}
  >
    <slot />
  </button>
  <div
    id={id}
    role="tooltip"
    popover="manual"
    data-tooltip-bubble
    class="tooltip-bubble max-w-[min(20rem,calc(100vw-1.5rem))] rounded-lg border border-secondary/30 bg-content2/95 px-4 py-3 text-sm shadow-xl backdrop-blur-sm"
  >
    <span class="flex gap-2">
      {
        icon && (
          <Icon
            aria-hidden="true"
            name="tabler:info-circle"
            size={16}
            class="mt-0.5 shrink-0 text-secondary"
          />
        )
      }
      <span class="flex flex-col gap-1.5">
        {title && <span class="text-sm font-semibold text-secondary">{title}</span>}
        <span class="whitespace-pre-line leading-relaxed text-foreground/90">
          {content}
        </span>
      </span>
    </span>
  </div>
</span>

<script>
  import { initTooltipGlobals, setupTooltips } from '@/scripts/tooltip'

  initTooltipGlobals()
  document.addEventListener('astro:page-load', () => setupTooltips())
</script>

<style>
  .tooltip-root {
    position: relative;
    display: inline-block;
  }
  .tooltip-trigger {
    font: inherit;
    appearance: none;
    border: 0;
    background: none;
    padding: 0;
  }
  .tooltip-bubble {
    position: fixed;
    inset: auto;
    margin: 0;
    width: max-content;
    opacity: 0;
    translate: 0 4px;
    transition:
      opacity 0.15s ease,
      translate 0.15s ease,
      overlay 0.15s ease allow-discrete,
      display 0.15s ease allow-discrete;
  }
  .tooltip-bubble:popover-open {
    opacity: 1;
    translate: 0 0;
  }
  @starting-style {
    .tooltip-bubble:popover-open {
      opacity: 0;
      translate: 0 4px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .tooltip-bubble {
      transition: none;
      translate: none;
    }
  }
</style>
