---
import { Icon } from 'astro-icon/components'

interface Props {
  align?: 'left' | 'right'
  summaryClass?: string
  panelClass?: string
  ariaLabel?: string
  tooltip?: string
  class?: string
}

const {
  align = 'left',
  summaryClass = '',
  panelClass = '',
  ariaLabel,
  tooltip,
  class: className = '',
} = Astro.props

const tooltipId = tooltip ? `dropdown-tip-${crypto.randomUUID()}` : undefined
---

<details
  class:list={['dropdown relative', className]}
  data-dropdown
  data-tooltip={tooltip ? '' : undefined}
  data-tooltip-hover-only={tooltip ? '' : undefined}
>
  <summary
    class:list={['dropdown-summary list-none cursor-pointer', summaryClass]}
    aria-label={ariaLabel}
    data-tooltip-trigger={tooltip ? '' : undefined}
    aria-describedby={tooltipId}
  >
    <slot name="trigger" />
  </summary>
  <div
    class:list={[
      'dropdown-panel absolute z-50 mt-2 rounded-xl border border-divider bg-content1 p-2 shadow-xl',
      align === 'right' ? 'right-0' : 'left-0',
      panelClass,
    ]}
    data-dropdown-panel
  >
    <slot />
  </div>
  {
    tooltip && (
      <span
        id={tooltipId}
        role="tooltip"
        popover="manual"
        data-tooltip-bubble
        class="tooltip-bubble flex items-center gap-1.5 rounded-md border border-divider bg-content3 px-2.5 py-1.5 text-xs font-medium text-foreground shadow-lg"
      >
        <Icon
          aria-hidden="true"
          name="tabler:info-circle"
          size={14}
          class="shrink-0 text-default-400"
        />
        {tooltip}
      </span>
    )
  }
</details>

<script>
  import { initDropdownGlobals, setupDropdowns } from '@/scripts/dropdown'
  import { initTooltipGlobals, setupTooltips } from '@/scripts/tooltip'

  initDropdownGlobals()
  initTooltipGlobals()
  document.addEventListener('astro:page-load', () => {
    setupDropdowns()
    setupTooltips()
  })
</script>

<style>
  .dropdown-panel {
    transform-origin: top;
  }
  .dropdown :global(.dropdown-chevron) {
    transition: rotate 0.2s ease;
  }
  .dropdown[open] :global(.dropdown-chevron) {
    rotate: 180deg;
  }

  @media (prefers-reduced-motion: no-preference) {
    .dropdown[open] > .dropdown-panel {
      animation: dropdown-in 0.18s ease-out;
    }
    .dropdown[data-closing] > .dropdown-panel {
      animation: dropdown-out 0.15s ease-in forwards;
    }
    @keyframes dropdown-in {
      from {
        opacity: 0;
        transform: translateY(-6px) scale(0.98);
      }
    }
    @keyframes dropdown-out {
      to {
        opacity: 0;
        transform: translateY(-6px) scale(0.98);
      }
    }
  }
</style>

<style is:global>
  html.dropdown-active {
    overflow: hidden;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 30;
    background: rgb(0 0 0 / 0.4);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
  }
  html.dropdown-active body::after {
    opacity: 1;
    visibility: visible;
  }
</style>
