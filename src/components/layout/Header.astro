---
import Icon from '@/components/mdx/Icon.astro'
import Dropdown from '@/components/ui/Dropdown.astro'
import ThemeSwitch from './ThemeSwitch.astro'
import {
  getCategoryRoutes,
  STATIC_SEGMENTS,
  withLocalePrefix,
  type Locale,
} from '@/lib/routes'
import { t } from '@/i18n/messages'
import { PERSONAL } from '@/constants/site'

interface Props {
  locale: Locale
  alternates: Record<Locale, string>
}

const { locale, alternates } = Astro.props

const nav = [
  { label: t(locale, 'Navbar.home'), href: `/${locale}` },
  {
    label: t(locale, 'Navbar.categories'),
    href: `/${locale}/${STATIC_SEGMENTS.categories[locale]}`,
  },
  {
    label: t(locale, 'Navbar.resources'),
    href: `/${locale}/${STATIC_SEGMENTS.resources[locale]}`,
  },
  {
    label: t(locale, 'Navbar.about'),
    href: `/${locale}/${STATIC_SEGMENTS.about[locale]}`,
  },
]

const categories = (await getCategoryRoutes()).map((c) => ({
  title: c.entry[locale].data.title,
  href: withLocalePrefix(locale, c.path[locale]),
}))

const categoriesHref = `/${locale}/${STATIC_SEGMENTS.categories[locale]}`
const iconBtn =
  'p-2 rounded-full text-foreground/70 hover:text-foreground hover:bg-content3 transition-colors'
---

<header
  class="sticky top-0 z-40 border-b border-divider bg-background/80 backdrop-blur-md"
>
  <nav class="mx-auto max-w-5xl flex items-center justify-between px-4 h-16">
    <a href={`/${locale}`} class="flex items-center gap-2 font-bold">
      <img src="/logo.svg" alt="" width="26" height="26" />
      <span>{PERSONAL.name.short}</span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      <a
        href={nav[0].href}
        class="px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
      >
        {nav[0].label}
      </a>

      <Dropdown
        panelClass="w-64"
        summaryClass="flex items-center gap-1 px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
      >
        <Fragment slot="trigger">
          {nav[1].label}
          <Icon name="chevron-down" size={16} class="dropdown-chevron" />
        </Fragment>
        {
          categories.map((c) => (
            <a
              href={c.href}
              class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
            >
              <Icon name="folder" size={16} class="text-primary" />
              {c.title}
            </a>
          ))
        }
        <a
          href={categoriesHref}
          class="block px-3 py-2 rounded-lg text-sm text-primary hover:bg-content3 transition-colors"
        >
          {t(locale, 'Navbar.viewAllCategories')}
        </a>
      </Dropdown>

      <a
        href={nav[2].href}
        class="px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
      >
        {nav[2].label}
      </a>
      <a
        href={nav[3].href}
        class="px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
      >
        {nav[3].label}
      </a>
    </div>

    <div class="flex items-center gap-0.5">
      <button type="button" class={iconBtn} data-search-open aria-label="Search">
        <Icon name="search" size={20} />
      </button>
      <a
        href={`/${locale}/rss.xml`}
        class={`hidden sm:inline-flex ${iconBtn}`}
        aria-label="RSS"
      >
        <Icon name="rss" size={20} />
      </a>
      <a
        href={PERSONAL.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class={`hidden sm:inline-flex ${iconBtn}`}
        aria-label="GitHub"
      >
        <Icon name="brand-github" size={20} />
      </a>

      <Dropdown
        align="right"
        class="hidden sm:block"
        summaryClass={iconBtn}
        panelClass="w-32"
        ariaLabel="Language"
      >
        <Icon name="world" size={20} slot="trigger" />
        <a
          href={alternates['en-US']}
          class="block px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
          >English</a
        >
        <a
          href={alternates['pt-BR']}
          class="block px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
          >Português</a
        >
      </Dropdown>

      <ThemeSwitch />

      <Dropdown
        align="right"
        class="md:hidden"
        summaryClass={iconBtn}
        panelClass="w-60"
        ariaLabel={t(locale, 'Navbar.openMenu')}
      >
        <Icon name="menu-2" size={22} slot="trigger" />
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="block px-3 py-2 rounded-lg hover:bg-content3 transition-colors"
            >
              {item.label}
            </a>
          ))
        }
        <div class="my-2 border-t border-divider"></div>
        <div class="flex items-center gap-1 px-1">
          <a href={alternates['en-US']} class={iconBtn}>EN</a>
          <a href={alternates['pt-BR']} class={iconBtn}>PT</a>
          <a href={`/${locale}/rss.xml`} class={iconBtn} aria-label="RSS">
            <Icon name="rss" size={20} />
          </a>
          <a
            href={PERSONAL.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class={iconBtn}
            aria-label="GitHub"
          >
            <Icon name="brand-github" size={20} />
          </a>
        </div>
      </Dropdown>
    </div>
  </nav>
</header>
