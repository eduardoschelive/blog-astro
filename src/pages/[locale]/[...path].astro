---
import { getAllRoutes, type PageRoute } from '../../lib/routes'
import { getPageSeo } from '../../lib/seo'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleBody from '../../components/mdx/ArticleBody.astro'

// Single catch-all: translated segments rule out per-page files, so one route
// dispatches home/categories/about/resources/category/article. An undefined
// `path` renders the home page (/en-US, /pt-BR).
export async function getStaticPaths() {
  const routes = await getAllRoutes()
  return routes.map((route) => ({
    params: { locale: route.locale, path: route.path || undefined },
    props: route,
  }))
}

type Props = PageRoute
const route = Astro.props
const { locale, type } = route
const seo = getPageSeo(route)
---

<BaseLayout locale={locale} seo={seo} navAlternates={route.alternates}>
  <main class="mx-auto max-w-3xl px-4 py-10">
    {
      type === 'article' && route.article ? (
        <>
          <h1 class="text-4xl font-bold mb-8">{route.article.data.title}</h1>
          <ArticleBody entry={route.article} />
        </>
      ) : (
        <>
          <h1 class="text-4xl font-bold">{seo.title}</h1>
          <p class="mt-2 text-foreground/70">type: {type} · locale: {locale}</p>
        </>
      )
    }
  </main>
</BaseLayout>
