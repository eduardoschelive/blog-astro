---
import { getAllRoutes, type PageRoute } from '@/lib/routes'
import { getPageSeo } from '@/lib/seo'
import BaseLayout from '@/layouts/BaseLayout.astro'
import HomePage from '@/components/pages/HomePage.astro'
import CategoriesPage from '@/components/pages/CategoriesPage.astro'
import CategoryPage from '@/components/pages/CategoryPage.astro'
import ArticlePage from '@/components/pages/ArticlePage.astro'
import AboutPage from '@/components/pages/AboutPage.astro'
import ResourcesPage from '@/components/pages/ResourcesPage.astro'

export async function getStaticPaths() {
  const routes = await getAllRoutes()
  return routes.map((route) => ({
    params: { locale: route.locale, path: route.path || undefined },
    props: route,
  }))
}

type Props = PageRoute
const route = Astro.props
const { locale, type } = route
const seo = getPageSeo(route)
---

<BaseLayout locale={locale} seo={seo} navAlternates={route.alternates}>
  {type === 'home' && <HomePage locale={locale} />}
  {type === 'categories' && <CategoriesPage locale={locale} />}
  {type === 'category' && <CategoryPage route={route} />}
  {type === 'article' && <ArticlePage route={route} />}
  {type === 'about' && <AboutPage locale={locale} />}
  {type === 'resources' && <ResourcesPage locale={locale} />}
</BaseLayout>
